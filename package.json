{
  "name": "mdn-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Vietnamese MDN Web Docs snapshot and Cloudflare Worker for mdn.go-mizu.dev",
  "type": "module",
  "scripts": {
    "build:static": "node ./scripts/export-static.mjs",
    "dev": "wrangler dev",
    "dev:wrangler": "wrangler dev",
    "preview": "node ./scripts/preview-local.mjs",
    "deploy": "npm run build:static && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "mdn",
    "vietnamese",
    "static-site"
  ],
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.81.0"
  }
}
